{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dopamine-factory.pages.dev/dunsmile/services.schema.json",
  "title": "Dunsmile Service Manifest",
  "type": "object",
  "required": ["version", "services"],
  "properties": {
    "version": { "type": "string" },
    "updatedAt": { "type": "string" },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "name", "fullName", "category", "status", "route", "homeVisible", "module", "tags",
          "updatedAt", "estimatedDuration", "questionCount", "featuredRank", "trendingScore"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "fullName": { "type": "string" },
          "emoji": { "type": "string" },
          "desc": { "type": "string" },
          "category": { "type": "string", "enum": ["fortune", "luck", "finance", "fun", "utility", "experimental"] },
          "status": { "type": "string", "enum": ["active", "beta", "planned", "disabled"] },
          "route": { "type": "string", "pattern": "^/dunsmile/.+/$" },
          "homeVisible": { "type": "boolean" },
          "shellEnabled": { "type": "boolean" },
          "module": {
            "type": "object",
            "required": ["type", "entry"],
            "properties": {
              "type": { "type": "string", "enum": ["legacy-page", "shell-module"] },
              "entry": { "type": "string" }
            }
          },
          "ogImage": { "type": "string" },
          "updatedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "estimatedDuration": { "type": "integer", "minimum": 1 },
          "questionCount": { "type": "integer", "minimum": 0 },
          "featuredRank": { "type": "integer", "minimum": 0 },
          "trendingScore": { "type": "number", "minimum": 0 },
          "socialProof": {
            "type": "object",
            "required": ["views", "likes"],
            "properties": {
              "views": { "type": "integer", "minimum": 0 },
              "likes": { "type": "integer", "minimum": 0 }
            }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
